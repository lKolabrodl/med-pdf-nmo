{
  "name": "nmo-pdf-easy-browser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-first NMO PDF answer predictor packaged as a plain JS library.",
  "main": "dist/nmo-pdf-easy.browser.js",
  "scripts": {
    "build": "esbuild src/browser.ts --bundle --format=iife --global-name=NmoPdfEasy --outfile=dist/nmo-pdf-easy.browser.js --platform=browser --target=es2020 --external:pdfjs-dist/legacy/build/pdf.mjs --legal-comments=none",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "predict": "tsx src/cli.ts",
    "eval": "tsx scripts/eval.ts --split dev",
    "eval:holdout": "tsx scripts/eval.ts --split holdout"
  },
  "dependencies": {
    "pdfjs-dist": "^5.7.284"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.27.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
